{
	"[luau]": {
		"editor.formatOnSave": true,
		"editor.defaultFormatter": "JohnnyMorganz.stylua"
	},

	"stylua.targetReleaseVersion": "latest",

	"editor.detectIndentation": false,
	"editor.insertSpaces": false,
	"files.eol": "\n",

	"luau-lsp.diagnostics.workspace": true,

	"luau-lsp.fflags.enableNewSolver": true,
	"luau-lsp.fflags.enableByDefault": false,
	"luau-lsp.fflags.override": {
		"LuauConst2": "true",
		"LuauIntegerType": "true",
		"LuauIntegerLibrary": "true",
	},

	"luau-lsp.platform.type": "roblox",
	"luau-lsp.sourcemap.enabled": false,
	"luau-lsp.studioPlugin.enabled": false,

	"luau-lsp.completion.imports.suggestServices": false,
	"luau-lsp.completion.imports.suggestRequires": true,
	"luau-lsp.completion.imports.stringRequires.enabled": true,
	
	"luau-lsp.ignoreGlobs": [
		"**/_Index/**",
		"vendor/**",
		".typedefs/**",
		"**/out/**",
		"*.d.luau",
		"**/luau_packages/**",
		"temp/**"
	],
}
